{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "style": "warn"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-console": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/", "scripts/"]
}
