{
  "name": "@fridzema/faker-quotes",
  "version": "0.1.0",
  "description": "A custom Faker provider for generating quotes. TypeScript port of fridzema/faker-quotes.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "bun test",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@faker-js/faker": "^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bun": "^1.3.11",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "faker",
    "quotes",
    "testing",
    "mock",
    "data",
    "typescript",
    "faker-provider"
  ],
  "author": "fridzema",
  "license": "MIT",
  "homepage": "https://github.com/fridzema/faker-quotes-js#readme",
  "bugs": {
    "url": "https://github.com/fridzema/faker-quotes-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fridzema/faker-quotes-js.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
